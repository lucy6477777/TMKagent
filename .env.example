# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# The program loads .env automatically on startup.
# .env is git-ignored so your keys stay local.

# === Required ===

# OpenAI API key (for translation via GPT-4o-mini, TTS via TTS-1, and file transcription via Whisper)
OPENAI_API_KEY=sk-...

# Deepgram API key (for real-time streaming ASR in stream mode)
# Sign up: https://console.deepgram.com ($200 free credits, no credit card)
DEEPGRAM_API_KEY=

# === Optional ===

# OpenAI API base URL (only needed if using a proxy or compatible endpoint)
# OPENAI_BASE_URL=https://api.openai.com/v1

# LiveKit Cloud credentials (for cross-device RTC relay)
# Sign up: https://cloud.livekit.io (free tier, no credit card)
# LIVEKIT_URL=wss://your-project.livekit.cloud
# LIVEKIT_API_KEY=APIxxxxx
# LIVEKIT_API_SECRET=
